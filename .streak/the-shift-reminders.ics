BEGIN:VEVENT
UID:the-shift-block-01-morning-launch@streak
DTSTART:20260411T090000
DTEND:20260411T094500
SUMMARY:🌅 The Shift — Morning Launch
DESCRIPTION:Drink two glasses of water\, expose eyes to 5000K+ light\, take Morning Stack (B12 sublingually\, Nootropic before food\, Omega-3 with breakfast).\n\nPriority: Medium
RRULE:FREQ=DAILY;COUNT=30
BEGIN:VALARM
ACTION:DISPLAY
DESCRIPTION:Morning Launch — water\, light\, supplements
TRIGGER:-PT15M
END:VALARM
END:VEVENT

